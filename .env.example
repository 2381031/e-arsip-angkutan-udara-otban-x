# Neon PostgreSQL (wajib di Vercel → Settings → Environment Variables)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# JWT untuk autentikasi (wajib di Vercel)
JWT_SECRET="ganti-dengan-kunci-rahasia-yang-kuat"

# Vercel Blob — untuk upload dokumen di production (wajib jika pakai fitur upload)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
