{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "jsx": "react-jsx",

    "strict": false,
    "skipLibCheck": true,

    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "resolveJsonModule": true,
    "isolatedModules": true,

    "noEmit": true,

    "types": [
      "node", 
      "react",
      "react-dom",
      "vite/client"
    ],

    "baseUrl": ".",

    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },

  "include": [
    "src",
    "server",
    "server.ts",
    "vite.config.ts"
  ],

  "exclude": [
    "dist",
    "node_modules"
  ]
}